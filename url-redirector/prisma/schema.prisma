generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Link {
  id        String   @id @default(cuid())
  slug      String   @unique
  targetUrl String
  clicks    Int      @default(0)
  createdAt DateTime @default(now())
}
